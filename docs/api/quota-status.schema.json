{
  "$id": "https://github.com/nevinsm/sol/internal/cliapi/quota/status-response",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "accounts": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "handle": {
            "type": "string"
          },
          "last_used_at": {
            "format": "date-time",
            "type": "string"
          },
          "limited_at": {
            "format": "date-time",
            "type": "string"
          },
          "remaining": {
            "type": "integer"
          },
          "resets_at": {
            "format": "date-time",
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "window": {
            "type": "string"
          }
        },
        "required": [
          "handle",
          "status"
        ],
        "type": "object"
      },
      "type": "array"
    }
  },
  "required": [
    "accounts"
  ],
  "type": "object"
}
