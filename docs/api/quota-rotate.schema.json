  "additionalProperties": false,
  "properties": {
    "actions": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "agent": {
            "type": "string"
          },
          "from_account": {
            "type": "string"
          },
          "paused": {
            "type": "boolean"
          },
          "to_account": {
            "type": "string"
          }
